{
  "name": "react-docx-monorepo",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@9.15.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/extend-hq/react-docx.git"
  },
  "bugs": {
    "url": "https://github.com/extend-hq/react-docx/issues"
  },
  "homepage": "https://github.com/extend-hq/react-docx#readme",
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "build": "pnpm --filter @extend-ai/react-docx-wasm run build && pnpm -r --filter './packages/*' run build",
    "clean": "pnpm -r --filter './packages/*' run clean",
    "dev": "pnpm --filter @extend-ai/react-docx-playground dev",
    "typecheck": "pnpm -r --filter './packages/*' run typecheck && pnpm --filter @extend-ai/react-docx-playground typecheck",
    "test": "pnpm run test:unit && pnpm run test:word-oracle && pnpm run test:visual",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:word-oracle": "node --test tests/fidelity/*.test.mjs",
    "test:visual": "playwright test tests/visual/fidelity-smoke.spec.ts tests/visual/annotation-roundtrip.spec.ts",
    "test:visual:update": "playwright test tests/visual/fidelity-smoke.spec.ts tests/visual/annotation-roundtrip.spec.ts --update-snapshots",
    "test:docx-regression": "pnpm run test:docx-regression:visual",
    "test:docx-regression:visual": "playwright test tests/visual/docx-regression.spec.ts",
    "test:docx-regression:update": "pnpm run test:docx-regression:visual --update-snapshots",
    "test:docx-vs-libreoffice": "node scripts/verify-docx-fidelity-corpus.mjs",
    "word-oracle:record": "node scripts/word-oracle/record-reference.mjs",
    "word-oracle:validate": "node scripts/word-oracle/validate-manifest.mjs",
    "word-oracle:materialize": "node scripts/word-oracle/materialize-references.mjs",
    "word-oracle:font-fingerprint": "node scripts/word-oracle/font-fingerprint.mjs",
    "word-oracle:capture": "node scripts/word-oracle/capture-viewer-pages.mjs",
    "word-oracle:compare": "node scripts/word-oracle/compare-pages.mjs",
    "word-oracle:edit-roundtrip": "node scripts/word-oracle/run-edit-roundtrip.mjs",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "publish-packages": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.5",
    "@extend-ai/react-docx-doc-model": "workspace:*",
    "@extend-ai/react-docx-editor-ops": "workspace:*",
    "@extend-ai/react-docx-layout-core": "workspace:*",
    "@extend-ai/react-docx-layout-engine": "workspace:*",
    "@extend-ai/react-docx-ooxml-core": "workspace:*",
    "@extend-ai/react-docx-serializer": "workspace:*",
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.6"
  },
  "pnpm": {
    "overrides": {
      "lodash": "4.18.1",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "vite": "6.4.2"
    }
  }
}
