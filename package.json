{
  "name": "react-docx-monorepo",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@9.15.0",
  "type": "module",
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "build": "pnpm -r --filter './packages/*' run build",
    "clean": "pnpm -r --filter './packages/*' run clean",
    "dev": "pnpm --filter @react-docx/playground dev",
    "typecheck": "pnpm -r --filter './packages/*' run typecheck && pnpm --filter @react-docx/playground typecheck",
    "test": "pnpm run test:unit && pnpm run test:visual",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:visual": "playwright test --pass-with-no-tests",
    "test:visual:update": "playwright test --update-snapshots --pass-with-no-tests",
    "test:docx-regression": "pnpm run test:docx-regression:visual",
    "test:docx-regression:visual": "playwright test tests/visual/docx-regression.spec.ts --pass-with-no-tests",
    "test:docx-regression:update": "pnpm run test:docx-regression:visual --update-snapshots",
    "test:docx-vs-libreoffice": "node scripts/compare-docx-to-libreoffice.mjs",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "publish-packages": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.5",
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^2.1.9"
  }
}
