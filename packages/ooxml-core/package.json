{
  "name": "@extend-ai/react-docx-ooxml-core",
  "private": true,
  "version": "0.1.0",
  "description": "OOXML package parsing and part management",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "dependencies": {
    "@extend-ai/react-docx-wasm": "workspace:*"
  },
  "publishConfig": {
    "access": "restricted"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --sourcemap --clean",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  }
}
