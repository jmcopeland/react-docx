{
  "name": "@extend-ai/react-docx",
  "version": "0.5.0",
  "description": "React components/hooks for DOCX viewing",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "restricted"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.5",
    "@tanstack/react-virtual": "^3.13.12",
    "fast-png": "^8.0.0",
    "utif": "^3.1.0"
  },
  "devDependencies": {
    "@extend-ai/react-docx-doc-model": "workspace:*",
    "@extend-ai/react-docx-editor-ops": "workspace:*",
    "@extend-ai/react-docx-layout-core": "workspace:*",
    "@extend-ai/react-docx-layout-engine": "workspace:*",
    "@extend-ai/react-docx-ooxml-core": "workspace:*",
    "@extend-ai/react-docx-serializer": "workspace:*"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  }
}
